{
  "name": "shadow",
  "version": "0.1.0",
  "private": true,
  "description": "Shadow — digital companion for engineering day-to-day",
  "type": "module",
  "bin": {
    "shadow": "dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --test $(find dist -type f -name '*.test.js' | sort)",
    "test:dev": "node --test $(find src -type f -name '*.test.ts' | sort)",
    "lint": "npm run typecheck",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.2.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
