{
  "name": "shadow",
  "version": "0.4.1",
  "private": true,
  "description": "Shadow — digital companion for engineering day-to-day",
  "type": "module",
  "bin": {
    "shadow": "dist/cli.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "npm run clean && tsc -p tsconfig.json && npm run dashboard:build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-test-module-mocks --test $(find dist -type f -name '*.test.js' | sort)",
    "test:dev": "node --experimental-test-module-mocks --import=tsx --test $(find src -type f -name '*.test.ts' -not -path '*/node_modules/*' | sort)",
    "lint": "npm run typecheck",
    "clean": "rm -rf dist",
    "dashboard:install": "cd src/web/dashboard && npm install",
    "dashboard:dev": "cd src/web/dashboard && npm run dev",
    "dashboard:build": "cd src/web/dashboard && npm run build"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "commander": "^14.0.0",
    "dotenv": "^17.2.1",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
