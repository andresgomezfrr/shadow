# Shadow configuration
# All variables are optional — defaults are sensible for local development.

# SHADOW_ENV=development
# SHADOW_DATA_DIR=~/.shadow
# SHADOW_LOG_LEVEL=info
# SHADOW_CLAUDE_BIN=claude
# SHADOW_CLAUDE_EXTRA_PATH=
# SHADOW_RUNNER_TIMEOUT_MS=600000
# SHADOW_HEARTBEAT_INTERVAL_MS=900000
# SHADOW_DAEMON_POLL_INTERVAL_MS=30000
# SHADOW_LOCALE=es

# Backend: cli (default, uses logged-in claude) or api (uses ANTHROPIC_API_KEY)
# SHADOW_BACKEND=cli

# Proactivity 1-10 (1=silent, 5=moderate, 10=full companion)
# SHADOW_PROACTIVITY_LEVEL=5

# Personality 1-5 (1=technical, 4=Tam-like companion, 5=full Tam)
# SHADOW_PERSONALITY_LEVEL=4

# Models per phase (sonnet, opus, haiku, or full model ID)
# SHADOW_MODEL_ANALYZE=sonnet
# SHADOW_MODEL_SUGGEST=opus
# SHADOW_MODEL_CONSOLIDATE=sonnet
# SHADOW_MODEL_RUNNER=sonnet
