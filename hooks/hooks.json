{
  "SessionStart": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "npx tsx ${CLAUDE_PLUGIN_ROOT}/src/cli.ts mcp-context"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write|Read|Bash|Grep",
      "hooks": [
        {
          "type": "command",
          "command": "${CLAUDE_PLUGIN_ROOT}/scripts/post-tool.sh",
          "async": true
        }
      ]
    }
  ]
}
